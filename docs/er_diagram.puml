@startuml er_diagram
left to right direction
skinparam linetype ortho
skinparam classAttributeIconSize 0
skinparam nodesep 40
skinparam ranksep 40
hide circle
hide methods

title ER-диаграмма — Видеохостинг-платформа

entity "Роль" as role {
    * id
    --
    * название
}

entity "Пользователь" as user {
    * id
    --
    * роль
    * имя пользователя
    * электронная почта
    * хеш пароля
    * дата регистрации
    * уведомления включены
    путь к аватару
}

entity "Канал" as channel {
    * id
    --
    * владелец
    * название
    описание
    * дата создания
}

entity "Видео" as video {
    * id
    --
    * канал
    * заголовок
    описание
    * путь к файлу
    * путь к превью
    * дата публикации
}

entity "Плейлист" as playlist {
    * id
    --
    * канал
    * название
    описание
    * дата создания
}

entity "Комментарий" as comment {
    * id
    --
    * автор
    * видео
    родительский комментарий
    * содержание
    * дата создания
}

entity "Просмотр" as watch_history {
    * id
    --
    * пользователь
    * видео
    * дата просмотра
}

entity "Уведомление" as notification {
    * id
    --
    * пользователь
    комментарий
    видео
    * тип
    * прочитано
    * дата создания
}

' ===== Связи =====

role ||--o{ user
user ||--o{ channel

channel ||--o{ video
channel ||--o{ playlist

user }o--o{ channel

playlist }o--o{ video

video ||--o{ comment
video ||--o{ watch_history
video ||--o{ notification

user ||--o{ comment
user ||--o{ watch_history
user ||--o{ notification

user }o--o{ video

comment ||--o{ comment
comment ||--o{ notification

user }o--o{ comment

@enduml
